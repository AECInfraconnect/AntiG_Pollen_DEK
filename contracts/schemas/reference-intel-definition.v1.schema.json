{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pollek.ai/schemas/reference-intel-definition.v1.schema.json",
  "title": "Pollek Reference Intel Definition",
  "description": "Compact external reference metadata keyed by observed entity fingerprints. Reference intel enriches UI context but is not enforcement evidence.",
  "type": "object",
  "required": [
    "id",
    "title",
    "vendor",
    "category",
    "description",
    "controlNotes",
    "sourceLabel",
    "sourceUrl",
    "reviewedAt",
    "keywords",
    "entityKinds"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "vendor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320
    },
    "controlNotes": {
      "type": "string",
      "minLength": 1,
      "maxLength": 360
    },
    "sourceLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri",
      "maxLength": 320
    },
    "reviewedAt": {
      "type": "string",
      "format": "date"
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "uniqueItems": true
    },
    "vendorKeywords": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "uniqueItems": true
    },
    "entityKinds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "enum": ["agent", "tool", "resource", "policy", "identity"]
      },
      "uniqueItems": true
    },
    "visualIdentity": {
      "type": "object",
      "description": "Compact visual hint for inline dashboard rendering. This is a curated UI hint, not official trademark evidence or access evidence.",
      "required": ["icon", "label", "background", "foreground", "sourceLabel"],
      "properties": {
        "icon": {
          "type": "string",
          "enum": [
            "bot",
            "cloud",
            "folder",
            "globe",
            "message",
            "network",
            "plug",
            "server",
            "sparkles"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 0,
          "maxLength": 6
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "foreground": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "sourceLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        }
      },
      "additionalProperties": false
    },
    "expectedCapabilities": {
      "type": "array",
      "maxItems": 16,
      "description": "Compact standard capabilities expected for this well-known entity. UI may compare these with observed local evidence.",
      "items": {
        "type": "object",
        "required": ["id", "label", "keywords"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
