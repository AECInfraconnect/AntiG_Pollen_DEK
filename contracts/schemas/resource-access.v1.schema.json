{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollen.dev/schemas/resource-access.v1.schema.json",
  "title": "ResourceAccessPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "agent_label",
    "scope",
    "kind",
    "target_redacted",
    "target_hash",
    "mode",
    "decision",
    "enforced_for_real",
    "observed_at"
  ],
  "properties": {
    "agent_id": { "type": "string" },
    "agent_label": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["local", "cloud"]
    },
    "kind": {
      "type": "string",
      "enum": ["file", "folder", "database_local", "os_syscall", "config", "process", "clipboard", "web", "email", "cloud_drive", "database_cloud", "data_source", "api", "saas"]
    },
    "target_redacted": { "type": "string" },
    "target_hash": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["read", "write", "execute", "delete", "connect", "invoke"]
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "redact", "warn", "observed"]
    },
    "control_method": {
      "type": "string",
      "enum": [
        "mcp_stdio", "mcp_http",
        "linux_landlock", "linux_ebpf", "linux_seccomp",
        "windows_wfp_um", "windows_wfp_callout", "windows_etw",
        "macos_netext", "macos_endpoint_security"
      ]
    },
    "enforced_for_real": { "type": "boolean" },
    "bytes": { "type": "integer" },
    "count": { "type": "integer" },
    "classification": { "type": "string" },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
