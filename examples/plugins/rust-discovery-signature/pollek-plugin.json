{
  "schema_version": "pollek.plugin.v1",
  "id": "com.example.rust-discovery-signature",
  "name": "Rust Discovery Signature Example",
  "version": "0.1.0",
  "kind": "discovery.signature",
  "wit_world": "pollek:discovery/discovery-plugin@0.1.0",
  "abi": "component",
  "min_engine_version": "1.0.0",
  "os": ["windows", "linux", "macos"],
  "entry": "plugin.wasm",
  "capabilities": {
    "host": ["logging", "clock"],
    "http_out": [],
    "kv": [],
    "native": [],
