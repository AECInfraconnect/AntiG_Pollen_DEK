#!/usr/bin/env bash
set -e

echo "==========================================================="
echo "   Pollen DEK Pre-push Hook"
echo "==========================================================="

echo ""
echo "[1/4] Checking Rust code formatting..."
cargo fmt --all -- --check || (echo "❌ Rust formatting check failed. Run 'cargo fmt --all'" && exit 1)

echo ""
echo "[2/4] Checking Rust workspace compilation (excluding eBPF prog)..."
cargo check --workspace --exclude dek-ebpf-prog --exclude pii-redactor-plugin --locked || (echo "❌ Cargo check failed." && exit 1)

# TODO: Restore cargo clippy here once Rust 1.85 upgrade is complete
# echo "[3/4] Running Clippy..."
# cargo clippy --workspace --exclude dek-ebpf-prog --exclude pii-redactor-plugin --all-targets -- -D warnings || (echo "❌ Clippy failed." && exit 1)
echo ""
echo "[3/4] Skipping Clippy for now (waiting for Rust 1.85 upgrade)..."

echo ""
echo "[4/4] Validating Pollen Contracts (TypeSpec, OpenAPI, Schemas)..."
if [ -d "contracts" ]; then
  (cd contracts && npm ci && npm run test) || (echo "❌ Contract validation failed." && exit 1)
else
  echo "⚠️ 'contracts' directory not found. Skipping."
fi

echo ""
echo "[4/4] Validating Dashboard Build..."
if [ -d "apps/local-admin-dashboard" ]; then
  (cd apps/local-admin-dashboard && npm ci && npm run build) || (echo "❌ Dashboard build failed." && exit 1)
fi

echo ""
echo "✅ All pre-push checks passed successfully!"
echo "==========================================================="
exit 0
