{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bundle Manifest",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "issued_at": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "required": ["path", "sha256"]
      }
    },
    "signature": { "type": "string" }
  },
  "required": ["version", "issued_at", "files", "signature"]
}
