{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Entity Catalog",
  "type": "object",
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "attributes": { "type": "object" }
        },
        "required": ["id", "type"]
      }
    }
  },
  "required": ["entities"]
}
