{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Route",
  "type": "object",
  "properties": {
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path_prefix": { "type": "string" },
          "policy_id": { "type": "string" }
        },
        "required": ["path_prefix", "policy_id"]
      }
    }
  },
  "required": ["routes"]
}
