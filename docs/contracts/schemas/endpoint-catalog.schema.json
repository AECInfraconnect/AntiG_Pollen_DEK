{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Endpoint Catalog",
  "type": "object",
  "properties": {
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "protocol": { "type": "string" },
          "policy_route_tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "data_sensitivity_tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tls_requirements": {
            "type": "object",
            "properties": {
              "min_tls_version": { "type": "string" },
              "cert_fingerprints": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "required": ["id", "url", "protocol"]
      }
    }
  },
  "required": ["endpoints"]
}
